---
import { getCollection, type CollectionEntry } from 'astro:content'
import Layout from '../layouts/Layout.astro'

const posts = (await getCollection('posts')).sort(
	(a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
)
---
<Layout>
    <section>
        <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wider mb-6">Latest</h2>
        <ul class="space-y-3">
          {posts.map((post: CollectionEntry<'posts'>) => (
            <li>
                <a class="flex justify-between items-baseline group" href={`/posts/${post.id}`}>
                    <span class="text-lg text-stone-800 group-hover:text-stone-500 transition-colors">
                        {post.data.title}
                    </span>
                    <time datetime={post.data.publishedDate.toISOString()} class="text-sm text-stone-400">
                        {post.data.publishedDate.toLocaleDateString('en-US', {
                          year: 'numeric', month: 'short', day: 'numeric',
                          hour: '2-digit', minute: '2-digit'
                        })}
                    </time>
                </a>
            </li>
          ))}
        </ul>
    </section>
</Layout>
